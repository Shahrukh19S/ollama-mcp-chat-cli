# ============================================================================
# .env.example — committed template documenting the required variables.
# Copy this to ".env" and fill in real values. NEVER put real keys in here.
# Switch providers by changing LLM_PROVIDER + LLM_MODEL together:
#   ollama  -> LLM_MODEL=ollama_chat/qwen2.5:7b        (local, no key needed)
#   groq    -> LLM_MODEL=groq/openai/gpt-oss-120b      (needs GROQ_API_KEY)
#   github  -> LLM_MODEL=openai/gpt-4o-mini            (needs GITHUB_MODELS_*)
# ============================================================================

# --- Active provider (primary = local Ollama) ---
LLM_PROVIDER=ollama
LLM_MODEL=ollama_chat/qwen2.5:7b
OLLAMA_API_BASE=http://localhost:11434

# --- Fallback 1: Groq (free, strong/fast tool calling) ---
GROQ_API_KEY=your-groq-api-key-here

# --- Fallback 2: GitHub Models (free; ~50/day, ~8k input cap) ---
GITHUB_MODELS_API_KEY=your-github-pat-with-models-read-scope
GITHUB_MODELS_API_BASE=https://models.github.ai/inference

# Set to 1 if you're using uv to run the project; 0 if not.
USE_UV=1
